# ================================
# HORIZON HUB — Variáveis de Ambiente
# ================================
# Copie este arquivo para .env e ajuste os valores

# --- Servidor ---
NODE_ENV=development
PORT=3001

# --- Banco de Dados (Docker local) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=horizonhub
DB_USER=horizonhub
DB_PASSWORD=horizonhub_secret

# --- JWT ---
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SEGURA_DE_32_CHARS
JWT_EXPIRES_IN=7d

# --- SMTP (configurar nas Configurações do sistema) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Horizon HUB
SMTP_FROM_EMAIL=

# --- Frontend URL (CORS) ---
FRONTEND_URL=http://localhost:5173
